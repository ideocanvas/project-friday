# ===========================================
# Project Friday - Environment Configuration
# Copy this to .env and fill in your values
# ===========================================

# === LOCAL LLM (Chat & Fast Responses) ===
AI_PROVIDER=LM_STUDIO
AI_BASE_URL=http://localhost:1234/v1
CHAT_MODEL=qwen/qwen3.5-35b-a3b

# === TOOL CALLING ===
# Enable native tool calling (false = text extraction, true = tool calling API)
# When enabled, the format is determined by AI_PROVIDER:
#   - LM_STUDIO / openai: OpenAI-style tools with JSON Schema
#   - ollama: Ollama function calling format
TOOL_CALLING_ENABLED=true

# === AGENT LOOP ===
# Maximum number of LLM iterations per message (tool call → result → LLM → more tools or text)
# Higher values allow more complex multi-step tool chains
AGENT_MAX_ITERATIONS=5

# === INTENT TRIAGE ===
# Enable/disable intent triage (classifies messages as rapid_response, background_task, or skill_generation)
# When disabled, all messages go through the blocking agent loop
TRIAGE_ENABLED=true
# Max tokens for triage LLM call (keep small for speed)
TRIAGE_MAX_TOKENS=256
# Temperature for triage (low = more deterministic)
TRIAGE_TEMPERATURE=0.3
# Timeout for triage LLM call in milliseconds
TRIAGE_TIMEOUT_MS=15000

# === BACKGROUND TASKS ===
# Maximum iterations for background task agent loops (usually higher than blocking)
TASK_MAX_ITERATIONS=10
# Maximum log entries per task before rotation
TASK_LOG_MAX_ENTRIES=200

# === CONTEXT BLOCKS ===
# Time gap (in minutes) that separates conversation blocks
# Messages within this time gap are grouped together as one conversation
CONTEXT_BLOCK_GAP_MINUTES=30

# Number of conversation blocks before summarization kicks in
# Older blocks get summarized to reduce context length
CONTEXT_SUMMARY_THRESHOLD_BLOCKS=3
# Maximum context messages to include in LLM prompt
MAX_CONTEXT_MESSAGES=20

# === VISION MODEL ===
# Vision model for image analysis (e.g., llava:13b, moondream)
# Used by the vision skill to analyze screenshots and images
VISION_MODEL=qwen/qwen3.5-35b-a3b
# API type for the vision endpoint: "ollama" or "openai" (OpenAI-compatible, e.g. LM Studio)
# Determines the request format and endpoint path used for vision calls
VISION_API_TYPE=openai
# Optional: Different endpoint for vision (defaults to AI_BASE_URL)
# For Ollama vision models, use: http://localhost:11434
VISION_BASE_URL=http://localhost:1234/v1

# === CLOUD LLM (GLM-5 for Evolution) ===
# Ollama Cloud - runs locally on port 11434
CLOUD_AI_KEY=ollama
CLOUD_AI_URL=http://localhost:11434
EVOLUTION_MODEL=glm-5:cloud

# === AUDIO (MLX-Audio for Apple Silicon) ===
TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-Base-bf16
STT_MODEL=mlx-community/ivrit-ai-whisper-large-v3-mlx

# === PATHS ===
USER_DATA_ROOT=./users
WEB_PORTAL_ROOT=./web_portal
SKILLS_PATH=./skills
QUEUE_PATH=./queue
TEMP_PATH=./temp

# === GPU RESOURCE ARBITER ===
# Lock file to prevent GPU conflicts between Local LLM, MLX-Audio, and Cloud Evolution
ARBITER_LOCK_PATH=./temp/gpu_active.lock

# === WHATSAPP ===
ALLOWED_NUMBERS=+1234567890,+0987654321
SESSION_PATH=./auth_info_baileys

# === GOOGLE SEARCH (Optional) ===
# Get from https://console.cloud.google.com
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_CX=your_search_engine_cx
SEARCH_MAX_RESULTS=10

# === DEEP RESEARCH ===
# LLM Configuration (generic — any OpenAI-compatible or Ollama API)
# Falls back to CHAT_MODEL/AI_BASE_URL if not set
DEEP_RESEARCH_LLM_MODEL=qwen/qwen3.5-35b-a3b
DEEP_RESEARCH_LLM_BASE_URL=http://localhost:1234/v1
DEEP_RESEARCH_LLM_API_TYPE=openai
# Optional: API key for authenticated cloud providers
DEEP_RESEARCH_LLM_API_KEY=
# Behavior
DEEP_RESEARCH_MAX_SOURCES=5
DEEP_RESEARCH_MAX_ITERATIONS=10
DEEP_RESEARCH_TIMEOUT_MS=120000
DEEP_RESEARCH_TEMP_DIR=./temp/deep_research
# Threshold (chars) above which results generate a static page instead of text
DEEP_RESEARCH_TEXT_THRESHOLD=1000

# === STATIC PAGE ===
# Cloudflare Tunnel URL for external access (used by AI to share links in chat)
# Set this to your Cloudflare tunnel URL when running the tunnel
# Example: https://project-friday.ideocanvas.com
# When set, generated page URLs will use this base URL instead of localhost
CLOUDFLARE_TUNNEL_URL=https://project-friday.ideocanvas.com
PAGE_EXPIRY_HOURS=24
MAX_DATA_SIZE_BYTES=1048576

# === WEB SERVER ===
WEB_SERVER_PORT=3000
WEB_SERVER_HOST=0.0.0.0

# === EVOLUTION ===
EVOLUTION_MAX_ROUNDS=10
EVOLUTION_ROUND_TIMEOUT_SEC=60
EVOLUTION_TOTAL_TIMEOUT_MIN=30

# === SCHEDULER ===
CHECK_INTERVAL_MS=60000

# === LOGGING ===
LOG_LEVEL=info
# === CONDA ===
# Optional: Specify conda environment name to run python skills
CONDA_ENV_NAME=mlx
