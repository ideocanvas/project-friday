# ===========================================
# Project Friday - Environment Configuration
# Copy this to .env and fill in your values
# ===========================================

# === LOCAL LLM (Chat & Fast Responses) ===
AI_PROVIDER=LM_STUDIO
AI_BASE_URL=http://localhost:1234/v1
CHAT_MODEL=qwen/qwen3.5-35b-a3b

# === TOOL CALLING ===
# Enable native tool calling (false = text extraction, true = tool calling API)
# When enabled, the format is determined by AI_PROVIDER:
#   - LM_STUDIO / openai: OpenAI-style tools with JSON Schema
#   - ollama: Ollama function calling format
TOOL_CALLING_ENABLED=false

# === VISION MODEL ===
# Vision model for image analysis (e.g., llava:13b, moondream)
# Used by the vision skill to analyze screenshots and images
VISION_MODEL=qwen/qwen3.5-35b-a3b
# Optional: Different endpoint for vision (defaults to AI_BASE_URL)
# For Ollama vision models, use: http://localhost:11434
# VISION_BASE_URL=http://localhost:11434

# === CLOUD LLM (GLM-5 for Evolution) ===
# Ollama Cloud - runs locally on port 11434
CLOUD_AI_KEY=ollama
CLOUD_AI_URL=http://localhost:11434
EVOLUTION_MODEL=glm-5:cloud

# === AUDIO (MLX-Audio for Apple Silicon) ===
TTS_MODEL=qwen3-tts
STT_MODEL=mlx-whisper-large-v3

# === PATHS ===
USER_DATA_ROOT=./users
WEB_PORTAL_ROOT=./web_portal
SKILLS_PATH=./skills
QUEUE_PATH=./queue
TEMP_PATH=./temp

# === GPU RESOURCE ARBITER ===
# Lock file to prevent GPU conflicts between Local LLM, MLX-Audio, and Cloud Evolution
ARBITER_LOCK_PATH=./temp/gpu_active.lock

# === WHATSAPP ===
ALLOWED_NUMBERS=+1234567890,+0987654321
SESSION_PATH=./auth_info_baileys

# === GOOGLE SEARCH (Optional) ===
# Get from https://console.cloud.google.com
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_CX=your_search_engine_cx
SEARCH_MAX_RESULTS=10

# === STATIC PAGE ===
# Cloudflare Tunnel URL for external access (used by AI to share links in chat)
# Set this to your Cloudflare tunnel URL when running the tunnel
# Example: https://project-friday.ideocanvas.com
# When set, generated page URLs will use this base URL instead of localhost
CLOUDFLARE_TUNNEL_URL=https://project-friday.ideocanvas.com
PAGE_EXPIRY_HOURS=24
MAX_DATA_SIZE_BYTES=1048576

# === WEB SERVER ===
WEB_SERVER_PORT=3000
WEB_SERVER_HOST=0.0.0.0

# === EVOLUTION ===
EVOLUTION_MAX_ROUNDS=10
EVOLUTION_ROUND_TIMEOUT_SEC=60
EVOLUTION_TOTAL_TIMEOUT_MIN=30

# === SCHEDULER ===
CHECK_INTERVAL_MS=60000

# === LOGGING ===
LOG_LEVEL=info