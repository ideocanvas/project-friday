{
  "name": "friday-project",
  "version": "1.0.0",
  "description": "Project Friday - A privacy-first, local AI assistant with WhatsApp integration",
  "main": "dist/core/gateway.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "npx pm2 start ecosystem.config.cjs",
    "stop": "npx pm2 stop all",
    "restart": "npx pm2 restart all",
    "logs": "npx pm2 logs",
    "status": "npx pm2 status",
    "gateway": "node dist/core/gateway.js",
    "scheduler": "node dist/core/heartbeat.js",
    "janitor": "node dist/core/janitor.js",
    "evolution": "node dist/core/evolution.js",
    "web-server": "node dist/core/web-server.js",
    "dev:gateway": "ts-node --esm core/gateway.ts",
    "dev:scheduler": "ts-node --esm core/heartbeat.ts",
    "dev:janitor": "ts-node --esm core/janitor.ts",
    "dev:evolution": "ts-node --esm core/evolution.ts",
    "dev:web-server": "ts-node --esm core/web-server.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:pages": "node --loader ts-node/esm scripts/generate-test-pages.ts",
    "test:cleanup": "node --loader ts-node/esm scripts/cleanup-test-pages.ts"
  },
  "keywords": [
    "ai",
    "assistant",
    "whatsapp",
    "local-llm",
    "mlx",
    "mac-mini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "pino": "^8.16.2",
    "playwright": "^1.40.1",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^9.0.1",
    "write-file-atomic": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@types/write-file-atomic": "^4.0.3",
    "jest": "^30.3.0",
    "pm2": "^5.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
